{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "phoenix",
  "watcher": {
    "ignore": [
      "_build",
      "deps",
      "*.tmp",
      ".elixir_ls",
      "priv/static/cache"
    ]
  },
  "agents": {
    "phoenix": ".opencode/agents/phoenix.md",
    "nerves": ".opencode/agents/nerves.md"
  },
  "autoupdate": "notify",
  "snapshot": true,
  "compaction": {
    "enabled": true,
    "strategy": "auto"
  },
  "share": {
    "enabled": false
  }
}
