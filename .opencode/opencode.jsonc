{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "watcher": {
    "ignore": [
      "_build",
      "deps",
      "*.tmp",
      ".elixir_ls",
      "priv/static/cache"
    ]
  },
  "autoupdate": "notify",
  "snapshot": true,
  "compaction": {
    "enabled": true,
    "strategy": "auto"
  },
  "share": "disabled"
}
