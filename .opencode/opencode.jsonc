{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "."
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory@2026.1.26"
      ]
    }
  },
  "watcher": {
    "ignore": [
      "_build",
      "deps",
      "coverage",
      "*.tmp",
      ".elixir_ls",
      "priv/static/cache",
      "assets/node_modules",
      "erl_crash.dump",
      ".opencode/node_modules",
      ".opencode/sessions"
    ]
  },
  "autoupdate": "notify",
  "snapshot": true,
  "compaction": {
    "enabled": true,
    "strategy": "auto"
  },
  "share": "disabled"
}
