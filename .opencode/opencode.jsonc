{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "."
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory@2026.1.26"
      ]
    }
  },
  "watcher": {
    "ignore": [
      "_build",
      "deps",
      "coverage",
      "*.tmp",
      ".elixir_ls",
      ".elixir_ls/**/*",
      "priv/static/cache",
      "assets/node_modules",
      "erl_crash.dump",
      ".opencode/node_modules",
      ".opencode/sessions",
      "node_modules",
      ".env",
      ".env.*",
      ".DS_Store",
      "*.swp",
      "*~",
      "__pycache__",
      ".pytest_cache"
    ]
  },
  "autoupdate": "notify",
  // Notify but don't auto-apply updates — lets users review changes before applying
  "snapshot": true,
  // Enable session snapshots for recovery
  "compaction": {
    "enabled": true,
    "strategy": "auto"
    // Automatically compact sessions to save disk space
  },
  "share": "disabled"
  // Disable sharing to keep sessions local/private
}
