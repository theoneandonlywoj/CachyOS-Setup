{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "watcher": {
    "ignore": [
      "_build",
      "deps",
      "*.tmp",
      ".elixir_ls",
      "priv/static/cache"
    ]
  },
  "mode": {
    "build": {
      "permission": {
        "edit": {
          "**/*.ex": "allow",
          "**/*.exs": "allow",
          "**/*.heex": "allow",
          "**/*.eex": "allow",
          "**/priv/*": "ask",
          "config/*.exs": "allow"
        },
        "bash": {
          "mix": "allow",
          "iex": "allow",
          "Phoenix": "allow",
          "nerves.*": "allow",
          "mix firmware": "allow",
          "mix burn": "allow"
        },
        "glob": {
          "**/*.ex": "allow",
          "**/*.exs": "allow",
          "**/*.heex": "allow"
        }
      }
    }
  },
  "autoupdate": "notify",
  "snapshot": true
}
